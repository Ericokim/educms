# Server
PORT=4000
NODE_ENV=development

# Database (Phase 2)
DATABASE_URL=postgresql://educms:educms@localhost:5432/educms

# Auth (Phase 4)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE=1d
BCRYPT_ROUNDS=10

# CORS
FRONTEND_URL=http://localhost:5173

# Caching (optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Uploads (Phase 9)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
