{
  "name": "educms",
  "version": "0.0.1",
  "private": true,
  "description": "EduCMS - Educational Content Management System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w packages/shared",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "qa:browser": "node scripts/qa-browser.mjs",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "playwright-core": "^1.60.0"
  }
}
